# =============================================================================
# OpenClaw — Environment Variables for Ultron Empire
# Copy to .env and fill in your values
# =============================================================================

# --- Core ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENCLAW_GATEWAY_TOKEN=generate-a-random-token-here
OPENCLAW_WEBHOOK_SECRET=generate-a-webhook-secret-here

# --- Ultron Backend ---
ULTRON_API_URL=http://localhost:8000
ULTRON_API_KEY=your-ultron-api-key-if-needed

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALLOWED_USERS=+919876543210

# --- WhatsApp (link via: openclaw channels login) ---
WHATSAPP_ALLOWED_NUMBERS=+919876543210

# --- Discord (optional) ---
# DISCORD_BOT_TOKEN=your-discord-bot-token

# --- Slack (optional) ---
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token

# --- Signal (optional) ---
# SIGNAL_NUMBER=+919876543210

# --- Microsoft Teams (optional) ---
# TEAMS_APP_ID=your-teams-app-id
# TEAMS_APP_PASSWORD=your-teams-app-password
