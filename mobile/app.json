{
  "expo": {
    "name": "Ultron Empire",
    "slug": "ultron-empire-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "ultron",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#003235",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pmssahihai.ultron"
    },
    "android": {
      "package": "com.pmssahihai.ultron",
      "adaptiveIcon": {
        "backgroundColor": "#003235"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      "expo-av",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://api.ultron.pmssahihai.com",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ultron-empire"
      }
    }
  }
}
